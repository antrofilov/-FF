        <div class="color-option" style="background-color: #2d3436;" data-color="#2d3436"></div>
        <div class="color-option" style="background-color: #4834d4;" data-color="#4834d4"></div>
        <div class="color-option" style="background-color: #130f40;" data-color="#130f40"></div>
        <div class="color-option" style="background-color: #22a6b3;" data-color="#22a6b3"></div>
        <div class="color-option" style="background-color: #be2edd;" data-color="#be2edd"></div>
        <div class="color-option" style="background-color: #ff9ff3;" data-color="#ff9ff3"></div>
        <div class="color-option" style="background-color: #feca57;" data-color="#feca57"></div>
        <div class="color-option" style="background-color: #ff6b6b;" data-color="#ff6b6b"></div>
        <div class="color-option" style="background-color: #48dbfb;" data-color="#48dbfb"></div>
        <div class="color-option" style="background-color: #1dd1a1;" data-color="#1dd1a1"></div>
        <div class="color-option" style="background-color: #00d2d3;" data-color="#00d2d3"></div>
        <div class="color-option" style="background-color: #54a0ff;" data-color="#54a0ff"></div>
        <div class="color-option" style="background-color: #5f27cd;" data-color="#5f27cd"></div>
        <div class="color-option" style="background-color: #341f97;" data-color="#341f97"></div>
    </div>

    <div class="notification" id="notification"></div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Элементы интерфейса
            const textInput = document.getElementById('text-input');
            const charCount = document.getElementById('char-count');
            const wordCount = document.getElementById('word-count');
            const sentenceCount = document.getElementById('sentence-count');
            const paragraphCount = document.getElementById('paragraph-count');
            const uniqueWordCount = document.getElementById('unique-word-count');
            const timeCount = document.getElementById('time-count');
            const scrollTrack = document.getElementById('scroll-track');
            const scrollThumb = document.getElementById('scroll-thumb');
            const menuButton = document.getElementById('menu-button');
            const colorPicker = document.getElementById('color-picker');
            const colorOptions = document.querySelectorAll('.color-option');
            const copyBtn = document.getElementById('copy-btn');
            const pasteBtn = document.getElementById('paste-btn');
            const clearBtn = document.getElementById('clear-btn');
            const notification = document.getElementById('notification');

            // Показать уведомление
            function showNotification(message) {
                notification.textContent = message;
                notification.style.opacity = '1';
                
                setTimeout(() => {
                    notification.style.opacity = '0';
                }, 2000);
            }

            // Расчет времени написания (100 слов в минуту)
            function calculateTime(wordCount) {
                const totalSeconds = Math.round((wordCount / 100) * 60);
                const minutes = Math.floor(totalSeconds / 60);
                const seconds = totalSeconds % 60;
                return `${minutes}м ${seconds}с`;
            }

            // Подсчет слов (улучшенный алгоритм)
            function countWords(text) {
                if (!text.trim()) return 0;
                
                const cleanedText = text.replace(/[^\wа-яА-Я']+/g, ' ');
                const words = cleanedText.split(/\s+/).filter(word => word.length > 0);
                return words.length;
            }

            // Подсчет уникальных слов
            function countUniqueWords(text) {
                if (!text.trim()) return 0;
                
                const cleanedText = text.toLowerCase().replace(/[^\wа-яА-Я']+/g, ' ');
                const words = cleanedText.split(/\s+/).filter(word => word.length > 0);
                return new Set(words).size;
            }

            // Инициализация скроллбара
            function initScrollbar() {
                const textHeight = textInput.scrollHeight;
                const containerHeight = textInput.clientHeight;
                const thumbHeight = Math.max(20, containerHeight * containerHeight / textHeight);
                
                scrollThumb.style.height = thumbHeight + 'px';
                
                if (textHeight <= containerHeight) {
                    scrollTrack.style.display = 'none';
                } else {
                    scrollTrack.style.display = 'block';
                }
            }

            // Обновление счетчиков
            function updateCounters() {
                const text = textInput.value;
                
                charCount.textContent = text.length;
                
                const wordCountValue = countWords(text);
                wordCount.textContent = wordCountValue;
                
                timeCount.textContent = calculateTime(wordCountValue);
                
                const sentences = text.split(/[.!?]+/).filter(s => s.trim().length > 0);
                sentenceCount.textContent = sentences.length;
                
                const paragraphs = text.split(/\n+/).filter(p => p.trim().length > 0);
                paragraphCount.textContent = paragraphs.length;
                
                uniqueWordCount.textContent = countUniqueWords(text);
                
                initScrollbar();
            }

            // Обработчики событий
            textInput.addEventListener('input', function() {
                updateCounters();
                
                const scrollRatio = textInput.scrollTop / (textInput.scrollHeight - textInput.clientHeight);
                const thumbPos = scrollRatio * (scrollTrack.clientHeight - scrollThumb.clientHeight);
                scrollThumb.style.top = thumbPos + 'px';
            });

            let isDragging = false;
            let startY = 0;
            let startTop = 0;

            scrollThumb.addEventListener('mousedown', function(e) {
                isDragging = true;
                startY = e.clientY;
                startTop = parseInt(scrollThumb.style.top) || 0;
                e.preventDefault();
            });

            document.addEventListener('mousemove', function(e) {
                if (!isDragging) return;
                
                const deltaY = e.clientY - startY;
                let thumbPos = startTop + deltaY;
                
                thumbPos = Math.max(0, thumbPos);
                thumbPos = Math.min(scrollTrack.clientHeight - scrollThumb.clientHeight, thumbPos);
                
                scrollThumb.style.top = thumbPos + 'px';
                
                const scrollRatio = thumbPos / (scrollTrack.clientHeight - scrollThumb.clientHeight);
                textInput.scrollTop = scrollRatio * (textInput.scrollHeight - textInput.clientHeight);
            });

            document.addEventListener('mouseup', function() {
                isDragging = false;
            });

            scrollTrack.addEventListener('click', function(e) {
                const trackRect = scrollTrack.getBoundingClientRect();
                const thumbPos = e.clientY - trackRect.top - scrollThumb.clientHeight / 2;
                
                const scrollRatio = Math.max(0, Math.min(1, thumbPos / scrollTrack.clientHeight));
                textInput.scrollTop = scrollRatio * (textInput.scrollHeight - textInput.clientHeight);
            });

            menuButton.addEventListener('click', function() {
                colorPicker.style.display = colorPicker.style.display === 'grid' ? 'none' : 'grid';
            });

            // Закрытие палитры при клике вне её области
            document.addEventListener('click', function(e) {
                if (!colorPicker.contains(e.target) && e.target !== menuButton) {
                    colorPicker.style.display = 'none';
                }
            });

            copyBtn.addEventListener('click', function() {
                if (textInput.value.trim() === '') {
                    showNotification('Нечего копировать');
                    return;
                }
                
                textInput.select();
                document.execCommand('copy');
                showNotification('Текст скопирован в буфер обмена');
                
                // Снимаем выделение текста
                window.getSelection().removeAllRanges();
            });

            pasteBtn.addEventListener('click', async function() {
                try {
                    const text = await navigator.clipboard.readText();
                    textInput.value += text;
                    updateCounters();
                    showNotification('Текст вставлен');
                } catch (err) {
                    showNotification('Не удалось вставить текст');
                    console.error('Ошибка при вставке:', err);
                }
            });

            clearBtn.addEventListener('click', function() {
                if (textInput.value.trim() === '') {
                    showNotification('Текст уже пуст');
                    return;
                }
                
                textInput.value = '';
                updateCounters();
                showNotification('Текст очищен');
            });

            colorOptions.forEach(option => {
                option.addEventListener('click', function() {
                    const newColor = option.getAttribute('data-color');
                    
                    colorOptions.forEach(opt => opt.classList.remove('active'));
                    option.classList.add('active');
                    
                    document.documentElement.style.setProperty('--bg-color', newColor);
                    
                    // Настройка цвета скроллбара в зависимости от выбранного фона
                    if (newColor === '#000000' || newColor === '#2c2c2c' || newColor === '#3d3d3d' || 
                        newColor === '#130f40' || newColor === '#2d3436' || newColor === '#341f97') {
                        document.documentElement.style.setProperty('--scroll-thumb', '#555555');
                    } else {
                        document.documentElement.style.setProperty('--scroll-thumb', '#5a8a8f');
                    }
                    
                    colorPicker.style.display = 'none';
                });
            });

            // Инициализация
            updateCounters();
            initScrollbar();
        });
    </script>
</body>
</html>
